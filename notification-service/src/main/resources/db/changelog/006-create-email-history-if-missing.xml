<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- This migration runs always and creates the table if it doesn't exist -->
    <!-- Also checks for NOTF_EMAIL_HISTORY since 007 renames the table -->
    <changeSet id="006-create-email-history-if-missing" author="system" runAlways="true">
        <preConditions onFail="MARK_RAN">
            <and>
                <not>
                    <tableExists tableName="EMAIL_HISTORY"/>
                </not>
                <not>
                    <tableExists tableName="NOTF_EMAIL_HISTORY"/>
                </not>
            </and>
        </preConditions>
        <createTable tableName="EMAIL_HISTORY">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="MESSAGE_ID" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="USER_ID" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="TENANT_ID" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
            <column name="RECIPIENT" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="SUBJECT" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
            <column name="TEMPLATE" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="VARIABLES" type="CLOB">
                <constraints nullable="true"/>
            </column>
            <column name="STATUS" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="RETRY_COUNT" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="ERROR_MESSAGE" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="SCHEDULED_AT" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="SENT_AT" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="CREATED_AT" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Ensure indexes exist on EMAIL_HISTORY (before rename) -->
    <!-- These will be skipped if NOTF_EMAIL_HISTORY exists (after rename by 007) -->
    <changeSet id="006-create-email-history-indexes" author="system" runAlways="true">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="EMAIL_HISTORY"/>
                <not>
                    <tableExists tableName="NOTF_EMAIL_HISTORY"/>
                </not>
                <not>
                    <indexExists tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_USER_ID"/>
                </not>
            </and>
        </preConditions>
        <createIndex tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_USER_ID">
            <column name="USER_ID"/>
        </createIndex>
    </changeSet>

    <changeSet id="006-create-tenant-index" author="system" runAlways="true">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="EMAIL_HISTORY"/>
                <not>
                    <tableExists tableName="NOTF_EMAIL_HISTORY"/>
                </not>
                <not>
                    <indexExists tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_TENANT_ID"/>
                </not>
            </and>
        </preConditions>
        <createIndex tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_TENANT_ID">
            <column name="TENANT_ID"/>
        </createIndex>
    </changeSet>

    <changeSet id="006-create-status-index" author="system" runAlways="true">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="EMAIL_HISTORY"/>
                <not>
                    <tableExists tableName="NOTF_EMAIL_HISTORY"/>
                </not>
                <not>
                    <indexExists tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_STATUS"/>
                </not>
            </and>
        </preConditions>
        <createIndex tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_STATUS">
            <column name="STATUS"/>
        </createIndex>
    </changeSet>

    <changeSet id="006-create-scheduled-index" author="system" runAlways="true">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="EMAIL_HISTORY"/>
                <not>
                    <tableExists tableName="NOTF_EMAIL_HISTORY"/>
                </not>
                <not>
                    <indexExists tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_SCHEDULED"/>
                </not>
            </and>
        </preConditions>
        <createIndex tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_SCHEDULED">
            <column name="SCHEDULED_AT"/>
        </createIndex>
    </changeSet>

    <changeSet id="006-create-message-id-index" author="system" runAlways="true">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="EMAIL_HISTORY"/>
                <not>
                    <tableExists tableName="NOTF_EMAIL_HISTORY"/>
                </not>
                <not>
                    <indexExists tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_MESSAGE_ID"/>
                </not>
            </and>
        </preConditions>
        <createIndex tableName="EMAIL_HISTORY" indexName="IDX_EMAIL_MESSAGE_ID">
            <column name="MESSAGE_ID"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
